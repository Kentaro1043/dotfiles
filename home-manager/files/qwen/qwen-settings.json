{
  "$version": 3,
  "ide": {
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "openai",
      "apiKey": "placeholder",
      "baseUrl": "http://localhost:11434/v1"
    }
  },
  "model": {
    "name": "qwen3-coder-next:cloud"
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "false"
      ]
    },
    "codex": {
      "command": "codex",
      "args": ["mcp-server"]
    }
  }
}
