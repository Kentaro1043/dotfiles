{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/refs/heads/main/schemas/settings.schema.json",
  "general": {
    "enableAutoUpdate": false,
    "preferredEditor": "codium"
  },
  "ui": {
    "theme": "Dracula"
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "security": {
    "toolSandboxing": false,
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "tools": {
    "sandbox": "sandbox-exec",
    "sandboxAllowedPaths": []
  },
  "mcpServers": {
    "context7": {
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "command": "npx"
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "false"
      ],
      "command": "uvx",
      "env": {
        "UV_TOOL_DIR": "./.tmp/uv/tool",
        "UV_CACHE_DIR": "./.tmp/uv/cache"
      }
    },
    "science-tokyo-syllabus": {
      "url": "https://syllabus.s.isct.ac.jp/mcp"
    }
  }
}
